# Provider padrão: mock | huggingface_space | cloud_webhook
DEFAULT_PROVIDER=mock

# Hugging Face Spaces
# Exemplo: Wan-AI/Wan2.1 ou outro Space público compatível com gradio_client
HF_SPACE_ID=
HF_API_NAME=/predict
HF_TOKEN=

# Cloud webhook genérico
# Use para APIs gratuitas, webhooks próprios ou provedores que retornem URL/arquivo de vídeo
CLOUD_WEBHOOK_URL=
CLOUD_WEBHOOK_KEY=

# Interface
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
